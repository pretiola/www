# Copy to .env for local runs. .env is gitignored.
# Production values live in GitHub repo secrets/variables and are pushed to Fly by the deploy workflow.

# Required: Web3Forms access key tied to the destination email.
# Get one at https://web3forms.com after registering contact@pretiola.org as the destination.
WEB3FORMS_ACCESS_KEY=

# Optional: override the destination email used in the formatted submission body.
# Defaults to contact@pretiola.org.
INTAKE_EMAIL=contact@pretiola.org

# Optional: where the JSONL audit log of accepted submissions is appended.
# Defaults to ./intake-log.jsonl
INTAKE_LOG_PATH=intake-log.jsonl
